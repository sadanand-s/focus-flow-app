# ─── Streamlit Secrets — DO NOT COMMIT THIS FILE ─────────────────────────────
# Copy this to .streamlit/secrets.toml and fill in values.
# This file is git-ignored. On Streamlit Cloud, add these under App Settings > Secrets.

[auth]
# A strong random secret key for the auth cookie (change this in production!)
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
cookie_key = "REPLACE_WITH_STRONG_RANDOM_SECRET_32_CHARS_MIN"

[gemini]
# Your Google Gemini API key (optional — can also be set in Settings page)
api_key = ""

[database]
# Optional: PostgreSQL/Supabase URL for cloud DB
# Leave empty to use SQLite (local only — not persisted on Streamlit Cloud)
url = ""
